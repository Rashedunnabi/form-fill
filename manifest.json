{
	"manifest_version": 3,
	"name": "Smart Form Fill",
	"version": "1.0.0",
	"description": "Save your personal form data once and fill it on any website.",
	"permissions": ["storage", "tabs"],
	"host_permissions": ["<all_urls>"],
	"action": {
		"default_title": "Smart Form Fill",
		"default_popup": "popup.html"
	},
	"options_page": "options.html",
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	]
}
